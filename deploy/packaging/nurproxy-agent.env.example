# NurProxy agent configuration (read by the systemd unit).
# Fill in the two required values, then: systemctl enable --now nurproxy-agent

# Orchestrator URL — must be reachable FROM THIS server (often different from
# the URL you use in your browser).
NP_ORCHESTRATOR=https://your-dashboard-url

# This agent's anchor hostname. Must be a name inside one of the DNS zones you
# will assign to it (e.g. edge1.example.com when the zone is example.com).
NP_FQDN=edge1.example.com
