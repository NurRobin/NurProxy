# Build
/dist/
/web/node_modules/
# Built dashboard assets are generated by `npm run build` (CI/release rebuild
# them before `go build`). Keep the dir so `//go:embed all:dist` still compiles.
/web/dist/*
!/web/dist/.gitkeep

